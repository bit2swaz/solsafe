# SolSafe local Telegram bot configuration
# 1. Open Telegram and message @BotFather.
# 2. Run /newbot to create a new bot, or /token to reveal an existing bot token.
# 3. Copy the token BotFather gives you.
# 4. Paste it after the = sign below with no quotes.
# Example format: 123456789:AAExampleTokenFromBotFather
BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN_HERE

# High-entropy shared secret for Telegram webhook verification.
# Telegram includes this value in X-Telegram-Bot-Api-Secret-Token when the webhook is registered.
TELEGRAM_WEBHOOK_SECRET=GENERATE_A_LONG_RANDOM_WEBHOOK_SECRET

# Helius free-tier API key for Solana Agent Kit RPC access.
# Create one at https://dashboard.helius.dev/ and keep it server-side only.
HELIUS_API_KEY=PASTE_HELIUS_API_KEY_HERE

# Groq API key for explainProgramLogs LLM summaries using the Llama 3.1 8B free tier.
# Create one at https://console.groq.com/ and keep it server-side only.
GROQ_API_KEY=PASTE_GROQ_API_KEY_HERE

# Supabase project URL and service role key for server-side query history, cache,
# and future conversation memory storage.
# Create them in your Supabase project settings and keep the service role key server-side only.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=PASTE_SUPABASE_SERVICE_ROLE_KEY_HERE

# Public dashboard URL used by the Telegram /link command.
# This should match the dashboard SIWS origin.
SIWS_ORIGIN=http://localhost:3000

# Public HTTPS URL that Telegram will POST updates to.
# For Render, this should be your service URL plus the webhook path below.
# Example: https://solsafe.onrender.com/telegram/webhook
WEBHOOK_URL=https://your-public-domain.example.com/telegram/webhook
